---
import { TELEGRAM_BOT } from '../consts';
---

<section class="cta-section">
    <div class="cta-section__glow" aria-hidden="true"></div>
    <div class="cta-section__inner">
        <div class="cta-section__card">
            <div class="cta-section__media">
                <img src="/imgs/home/3o.webp" alt="CraftTrade" class="cta-section__img" loading="lazy" />
            </div>
            <div class="cta-section__body">
                <h2 class="cta-section__title">
                    Начни торговать<br>с <span class="cta-accent">CraftTrade</span>
                </h2>
                <p class="cta-section__desc">
                    Обучим созданию стратегий, подключению к биржам и копированию подходов
                    профессиональных трейдеров. Присоединяйся к сообществу.
                </p>
                <a class="cta-section__btn" href={TELEGRAM_BOT}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.247l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.94z"/>
                    </svg>
                    Присоединиться в Telegram
                </a>
            </div>
        </div>
    </div>
</section>

<style>
.cta-section {
    position: relative;
    overflow: hidden;
    padding: 5rem 0;
}
.cta-section__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, oklch(0.75 0.195 145 / 0.06) 0%, transparent 65%);
    pointer-events: none;
}
.cta-section__inner {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
}
.cta-section__card {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1.75rem;
    padding: 3rem 3.5rem;
    box-shadow: 0 0 0 1px oklch(0.75 0.195 145 / 0.08), 0 24px 64px oklch(0 0 0 / 0.3);
}
.cta-section__media {
    flex-shrink: 0;
}
.cta-section__img {
    width: 200px;
    height: auto;
    border-radius: 1rem;
    display: block;
}
.cta-section__title {
    font-size: clamp(1.875rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    text-wrap: balance;
}
.cta-accent { color: var(--accent); }
.cta-section__desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 2rem;
    max-width: 44ch;
}
.cta-section__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--accent);
    color: oklch(0.12 0.022 248);
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    box-shadow: 0 0 24px oklch(0.75 0.195 145 / 0.3);
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}
.cta-section__btn:hover {
    background: var(--accent-light);
    box-shadow: 0 4px 32px oklch(0.75 0.195 145 / 0.48);
    transform: translateY(-2px);
}

@media (max-width: 700px) {
    .cta-section__card {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2rem;
        padding: 2rem 1.5rem;
    }
    .cta-section__media { display: none; }
    .cta-section__desc  { margin-left: auto; margin-right: auto; }
    .cta-section__btn   { margin: 0 auto; }
}
</style>
