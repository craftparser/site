---
import { TELEGRAM_BOT, TELEGRAM_CHANNEL } from '../consts';
---

<section class="hero">
    <div class="hero__dots" aria-hidden="true"></div>
    <div class="hero__glow-tr" aria-hidden="true"></div>

    <div class="hero__inner">
        <div class="hero__content">
            <h1 class="hero__title">
                Торговый бот<br>
                для <span class="hero__accent">крипторынка</span>
            </h1>
            <p class="hero__desc">
                Запусти автоматическую торговлю на BingX, ByBit или OKX
                прямо из Telegram. Работает 24/7 без вашего участия.
            </p>
            <div class="hero__stats">
                <div class="hero-stat">
                    <div class="hero-stat__val">99%</div>
                    <div class="hero-stat__lbl">Uptime</div>
                </div>
                <div class="hero-stat__sep"></div>
                <div class="hero-stat">
                    <div class="hero-stat__val">6%</div>
                    <div class="hero-stat__lbl">Комиссия с прибыли</div>
                </div>
                <div class="hero-stat__sep"></div>
                <div class="hero-stat">
                    <div class="hero-stat__val">$60</div>
                    <div class="hero-stat__lbl">Год подписки</div>
                </div>
            </div>
            <div class="hero__actions">
                <a class="btn-primary" href={TELEGRAM_BOT}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.247l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.94z"/>
                    </svg>
                    Начать торговлю
                </a>
                <a class="btn-secondary" href={TELEGRAM_CHANNEL}>
                    Telegram канал →
                </a>
            </div>
        </div>

        <div class="hero__visual">
            <div class="hero__img-wrap">
                <div class="hero__img-glow" aria-hidden="true"></div>
                <img
                    src="/imgs/home/mockup.webp"
                    alt="CraftTrade — интерфейс приложения"
                    class="hero__img"
                    width="480"
                    height="640"
                />
            </div>
        </div>
    </div>
</section>

<style>
.hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4.5rem;
    min-height: calc(90vh - 60px);
    display: flex;
    align-items: center;
}

.hero__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1.5px 1.5px, oklch(0.30 0.012 248 / 0.45) 1.5px, transparent 0);
    background-size: 40px 40px;
    pointer-events: none;
}
.hero__glow-tr {
    position: absolute;
    top: -15%;
    right: -8%;
    width: 55%;
    height: 85%;
    background: radial-gradient(ellipse at center, oklch(0.75 0.195 145 / 0.07) 0%, transparent 65%);
    pointer-events: none;
}

.hero__inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
    width: 100%;
}

.hero__title {
    font-size: clamp(2.5rem, 4.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.035em;
    margin: 0 0 1.375rem;
    text-wrap: balance;
}
.hero__accent { color: var(--accent); }

.hero__desc {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 40ch;
    margin: 0 0 2rem;
}

.hero__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.125rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    width: fit-content;
    margin-bottom: 2.5rem;
}
.hero-stat__val {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.2rem;
}
.hero-stat__lbl {
    font-size: 0.75rem;
    color: var(--ink-3);
    font-weight: 400;
    white-space: nowrap;
}
.hero-stat__sep {
    width: 1px;
    height: 2rem;
    background: var(--border);
    flex-shrink: 0;
}

.hero__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}
.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--accent);
    color: oklch(0.12 0.022 248);
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    box-shadow: 0 0 28px oklch(0.75 0.195 145 / 0.32);
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}
.btn-primary:hover {
    background: var(--accent-light);
    box-shadow: 0 4px 36px oklch(0.75 0.195 145 / 0.48);
    transform: translateY(-2px);
}
.btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    border: 1px solid var(--border);
    color: var(--ink-2);
    border-radius: 100px;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}
.btn-secondary:hover {
    border-color: var(--ink-3);
    color: var(--ink);
    transform: translateY(-1px);
}

.hero__visual {
    display: flex;
    justify-content: center;
}
.hero__img-wrap {
    position: relative;
    animation: float 4.5s ease-in-out infinite;
}
.hero__img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: 1.5rem;
    filter: drop-shadow(0 32px 64px oklch(0 0 0 / 0.55));
}
.hero__img-glow {
    position: absolute;
    bottom: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 35%;
    background: radial-gradient(ellipse at center, oklch(0.75 0.195 145 / 0.22) 0%, transparent 70%);
    filter: blur(24px);
    pointer-events: none;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-18px); }
}

@media (max-width: 900px) {
    .hero {
        padding: 3.5rem 0 3rem;
        min-height: auto;
    }
    .hero__inner {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2.5rem;
    }
    .hero__desc  { margin-left: auto; margin-right: auto; }
    .hero__stats { margin-left: auto; margin-right: auto; }
    .hero__actions { justify-content: center; }
    .hero__visual { order: -1; }
    .hero__img { max-width: 260px; }
}

@media (prefers-reduced-motion: reduce) {
    .hero__img-wrap { animation: none; }
}
</style>
