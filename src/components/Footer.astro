---
import { SITE_TITLE, TELEGRAM_BOT, TELEGRAM_CHANNEL, LINK_DOC, LINK_PARTNER } from '../consts';
import Metrika from './Metrika.astro';
---

<footer class="site-footer">
    <div class="site-footer__inner">
        <div class="site-footer__top">
            <div class="site-footer__brand">
                <a class="footer-logo" href="/">
                    {SITE_TITLE}
                </a>
                <p class="site-footer__disclaimer">
                    Команда Craft Trade является разработчиком программного обеспечения
                    и не предоставляет услуги трейдинга, обмена, переводов или кошельков.
                    Все упомянутые услуги осуществляются сторонними поставщиками.
                </p>
            </div>
            <nav class="site-footer__nav">
                <div class="footer-nav-group">
                    <div class="footer-nav-group__label">Ресурсы</div>
                    <a href={LINK_DOC}>Статьи</a>
                    <a href={LINK_PARTNER}>Партнёрская программа</a>
                </div>
                <div class="footer-nav-group">
                    <div class="footer-nav-group__label">Сообщество</div>
                    <a href={TELEGRAM_CHANNEL}>Telegram канал</a>
                    <a href={TELEGRAM_BOT}>Начать торговлю</a>
                </div>
            </nav>
        </div>
        <div class="site-footer__bottom">
            <span class="site-footer__meta">&copy; {new Date().getFullYear()} {SITE_TITLE}</span>
            <span class="site-footer__meta">Разработано в <a href="https://scrpt.ru">scrpt.ru</a></span>
        </div>
    </div>
</footer>

<Metrika />

<style>
.site-footer {
    border-top: 1px solid var(--border);
    background: oklch(0.15 0.020 248 / 0.7);
    margin-top: 2rem;
}
.site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
}
.site-footer__top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid oklch(0.28 0.012 248 / 0.5);
}
.site-footer__brand {
    max-width: 380px;
}
.footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 1rem;
}
.site-footer__disclaimer {
    font-size: 0.75rem;
    line-height: 1.65;
    color: var(--ink-3);
    margin: 0;
}
.site-footer__nav {
    display: flex;
    gap: 4rem;
}
.footer-nav-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.footer-nav-group__label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin-bottom: 0.25rem;
}
.footer-nav-group a,
.site-footer__meta a {
    text-decoration: none;
    transition: color 0.18s ease;
}
.footer-nav-group a {
    font-size: 0.875rem;
    color: var(--ink-2);
}
.footer-nav-group a:hover,
.site-footer__meta a:hover {
    color: var(--ink);
}
.site-footer__bottom {
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.site-footer__meta {
    font-size: 0.8125rem;
    color: var(--ink-3);
}
.site-footer__meta a {
    color: var(--ink-2);
}

@media (max-width: 700px) {
    .site-footer__top {
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    .site-footer__nav { gap: 2rem; }
    .site-footer__brand { max-width: none; }
}
</style>
