---
import { SITE_TITLE, TELEGRAM_BOT, TELEGRAM_CHANNEL, LINK_DOC } from '../consts';
---

<header class="site-header">
    <div class="site-header__inner">
        <a class="site-header__logo" href="/">
            <span class="logo-mark">CT</span>
            {SITE_TITLE}
        </a>
        <nav class="site-header__nav">
            <a href={TELEGRAM_CHANNEL}>Telegram</a>
            <a href={LINK_DOC}>Статьи</a>
            <a class="nav-cta" href={TELEGRAM_BOT}>Начать торговлю</a>
        </nav>
    </div>
</header>

<style>
.site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    background: oklch(0.13 0.022 248 / 0.88);
    border-bottom: 1px solid oklch(0.28 0.012 248 / 0.7);
}
.site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
}
.site-header__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
}
.logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.875rem;
    background: var(--accent);
    color: oklch(0.12 0.022 248);
    border-radius: 0.4rem;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0;
}
.site-header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
}
.site-header__nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 0.18s ease;
}
.site-header__nav a:hover {
    color: var(--ink);
}
.nav-cta {
    padding: 0.5rem 1.25rem;
    background: var(--accent) !important;
    color: oklch(0.12 0.022 248) !important;
    border-radius: 100px;
    font-weight: 600 !important;
    transition: background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease !important;
    box-shadow: 0 0 16px var(--accent-glow);
}
.nav-cta:hover {
    background: var(--accent-light) !important;
    box-shadow: 0 2px 24px oklch(0.75 0.195 145 / 0.4) !important;
    transform: translateY(-1px);
}

@media (max-width: 640px) {
    .site-header__inner {
        padding: 0.875rem 1.25rem;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
    }
    .site-header__nav { gap: 1.25rem; }
}
</style>
