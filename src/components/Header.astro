---
import { SITE_TITLE, TELEGRAM_BOT, TELEGRAM_CHANNEL, LINK_DOC } from '../consts';
import TelegramIcon from './TelegramIcon.astro';
---

<header class="site-header">
    <div class="site-header__inner">
        <a class="site-header__logo" href="/">
            {SITE_TITLE}
        </a>
        <nav class="site-header__nav">
            <a href={TELEGRAM_CHANNEL}>Telegram</a>
            <a href={LINK_DOC}>Статьи</a>
            <a class="nav-cta" href={TELEGRAM_BOT}>Начать торговлю</a>
        </nav>
        <button class="nav-burger" aria-label="Открыть меню" aria-expanded="false" aria-controls="mobile-menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav">
        <a href={TELEGRAM_CHANNEL}>Telegram канал</a>
        <a href={LINK_DOC}>Статьи</a>
        <a class="mobile-menu__cta" href={TELEGRAM_BOT}>
            <TelegramIcon />
            Начать торговлю
        </a>
    </nav>
</div>

<script>
const burger = document.querySelector('.nav-burger') as HTMLButtonElement;
const menu   = document.getElementById('mobile-menu') as HTMLElement;

burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.classList.toggle('is-open', !open);
    menu.classList.toggle('is-open', !open);
    menu.setAttribute('aria-hidden', String(open));
    document.body.style.overflow = open ? '' : 'hidden';
});

menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        burger.classList.remove('is-open');
        menu.classList.remove('is-open');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    });
});
</script>

<style>
.site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    background: oklch(0.13 0.022 248 / 0.88);
    border-bottom: 1px solid oklch(0.28 0.012 248 / 0.7);
}
.site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
}
.site-header__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
}
.site-header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
}
.site-header__nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 0.18s ease;
}
.site-header__nav a:hover {
    color: var(--ink);
}
.nav-cta {
    padding: 0.5rem 1.25rem;
    background: var(--accent) !important;
    color: oklch(0.12 0.022 248) !important;
    border-radius: 100px;
    font-weight: 600 !important;
    transition: background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease !important;
    box-shadow: 0 0 16px var(--accent-glow);
}
.nav-cta:hover {
    background: var(--accent-light) !important;
    box-shadow: 0 2px 24px oklch(0.75 0.195 145 / 0.4) !important;
    transform: translateY(-1px);
}

/* Burger */
.nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    flex-shrink: 0;
}
.nav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
}
.nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile fullscreen menu */
.mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 199;
    background: oklch(0.11 0.022 248 / 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
}
.mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
}
.mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
}
.mobile-menu__nav a {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--ink-2);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.18s ease;
}
.mobile-menu__nav a:hover {
    color: var(--ink);
}
.mobile-menu__cta {
    display: inline-flex !important;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.875rem 2rem !important;
    background: var(--accent) !important;
    color: oklch(0.12 0.022 248) !important;
    border-radius: 100px !important;
    font-size: 1.125rem !important;
    font-weight: 700 !important;
    box-shadow: 0 0 32px oklch(0.75 0.195 145 / 0.35);
}

@media (max-width: 640px) {
    .site-header__nav { display: none; }
    .nav-burger { display: flex; }
    .site-header__inner { padding: 0.875rem 1.25rem; }
}
</style>
