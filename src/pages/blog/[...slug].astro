---
import BaseHead from '../../components/BaseHead.astro';
import Footer   from '../../components/Footer.astro';
import Header   from '../../components/Header.astro';
import Home3o   from '../../components/Home3o.astro';

import { Image } from 'astro:assets';

import { getCollection, render } from 'astro:content';
const post = Astro.props;
const { Content } = await render(post);

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",      "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": "All Posts", "item": Astro.site + 'blog/' },
        { "@type": "ListItem", "position": 3, "name": post.data.title }
    ]
},{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "image": [ post.data.heroImage.src ],
    "datePublished": post.data.pubDate.toISOString(),
    "author": [{
        "@type": "Person",
        "name": "Craft Trade",
        "url": Astro.site
    }]
}];

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}

---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={post.data.title} description={post.data.description} />
        <script type="application/ld+json" set:html={JSON.stringify(json_ld)} />
        <meta property="og:image" content={post.data.heroImage.src} />
    </head>
	<body>
		<Header />
        <main class="post-main">

            <article class="post">
                <div class="post__inner">

                    <header class="post__header">
                        <div class="post__meta">
                            <a class="post__back" href="/blog/">← Все статьи</a>
                        </div>
                        <h1 class="post__title">{post.data.title}</h1>
                        {post.data.description && (
                            <p class="post__desc">{post.data.description}</p>
                        )}
                    </header>

                    {post.data.heroImage && (
                        <div class="post__cover">
                            <Image
                                loading="eager"
                                width={1024}
                                height={512}
                                src={post.data.heroImage}
                                alt={post.data.title}
                                class="post__cover-img"
                            />
                        </div>
                    )}

                    <div class="post__body prose">
                        <Content />
                    </div>

                    {post.data.author && (
                        <div class="post__author">
                            <Image
                                class="post__author-img"
                                loading="lazy"
                                width={80}
                                height={80}
                                src={post.data.author.img}
                                alt={post.data.author.name}
                            />
                            <div class="post__author-info">
                                <div class="post__author-name">{post.data.author.name}</div>
                                <div class="post__author-desc">{post.data.author.desc}</div>
                                {post.data.author.links?.length > 0 && (
                                    <div class="post__author-links">
                                        {post.data.author.links.map((a: string) => (
                                            <a href={a} class="post__author-link" target="_blank" rel="noopener">Профиль →</a>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </div>
                    )}

                </div>
            </article>

        </main>
        <Home3o />
		<Footer />
	</body>
</html>

<style>
.post-main {
    padding: 3rem 0 5rem;
}

.post__inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
}

.post__header {
    margin-bottom: 2.5rem;
}

.post__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 1rem;
}

.post__back {
    font-size: 0.875rem;
    color: var(--ink-3);
    text-decoration: none;
    transition: color 0.18s ease;
}
.post__back:hover { color: var(--accent); }

.post__date {
    font-size: 0.8125rem;
    color: var(--ink-3);
}

.post__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    text-wrap: balance;
}

.post__desc {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
}

.post__cover {
    margin-bottom: 3rem;
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--border);
}
.post__cover-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 480px;
}

.post__body {
    margin-bottom: 3rem;
}

.post__author {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1.125rem;
}
.post__author-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    border: 2px solid var(--border);
}
.post__author-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.375rem;
}
.post__author-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 0.75rem;
}
.post__author-links {
    display: flex;
    gap: 0.75rem;
}
.post__author-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.18s ease;
}
.post__author-link:hover { color: var(--accent-light); }

@media (max-width: 600px) {
    .post__author {
        flex-direction: column;
        text-align: center;
    }
    .post__author-links { justify-content: center; }
    .post__meta { flex-direction: column; align-items: flex-start; }
}
</style>
